{
  "name": "dinox",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "pnpm clean:next && next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "prisma:seed": "tsx prisma/seed.ts",
    "seed": "pnpm prisma:seed",
    "desktop:dev": "concurrently -k \"pnpm dev\" \"wait-on http://localhost:3000 && set DINOX_DEV_URL=http://localhost:3000 && electron .\"",
    "desktop:start": "electron .",
    "desktop:pack": "pnpm build && electron-builder --dir",
    "desktop:package:win": "pnpm build && node scripts/deref-symlinks.cjs && electron-builder --win nsis",
    "clean:next": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "qa:smoke:api": "pnpm build && pnpm qa:smoke:api:quick",
    "qa:smoke:api:quick": "concurrently -k -s first \"pnpm start --hostname 127.0.0.1 --port 3100\" \"wait-on http://127.0.0.1:3100/api/projects && node scripts/qa/smoke-api.mjs\"",
    "qa:smoke:exe:quick": "node scripts/qa/smoke-exe.mjs",
    "qa:smoke:exe": "pnpm desktop:pack && pnpm qa:smoke:exe:quick",
    "telegram": "node scripts/telegram-agent.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@prisma/client": "6.14.0",
    "@prisma/engines": "6.14.0",
    "chrono-node": "^2.9.0",
    "date-fns": "^4.1.0",
    "next": "16.1.6",
    "prisma": "6.14.0",
    "react": "19.2.3",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "main": "desktop/main.cjs",
  "build": {
    "appId": "com.japandino.dinox",
    "productName": "Dinox",
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/*.dll",
      ".next/standalone/.next/static/**/*",
      ".next/standalone/public/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "files": [
      "desktop/**/*",
      ".next/standalone/**/*",
      "prisma/schema.prisma",
      "prisma/migrations/**/*",
      "prisma/dev.db",
      "package.json"
    ],
    "icon": "build/icon.ico",
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "differentialPackage": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    }
  },
  "description": "Dinox local-first calendar for desktop and web",
  "author": "JapanDino <klim.i.rumyantsev@gmail.com>"
}
