# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production (electron-builder output — keep build/ for icon sources)
/release/win-unpacked
/release/*.exe
/release/*.blockmap
/release/*.yml

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

/prisma/dev.db

/.pnpm-store/

/release/

/output/

# local runtime db & logs
/.dinox-runtime/
.dev-server.*.log
null

# Claude Code local config
/.claude/settings.local.json

# Playwright artifacts
/.playwright-cli/
/.playwright-mcp/

# Prisma local dbs
/prisma/prisma/

# build logs (smoke/gate/installer)
build/*.log
